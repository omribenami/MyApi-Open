# MyApi Docker Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# This file is a template for Docker deployments. Copy to .env.local and fill
# in your actual values. NEVER commit .env.local — it contains real secrets.
#
# Usage:
#   cp .env.docker .env.local
#   # Edit .env.local with your real values
#   docker-compose up -d                          # production
#   docker-compose -f docker-compose.dev.yml up  # development
#
# Generate secrets:
#   openssl rand -hex 32                  # JWT_SECRET, SESSION_SECRET, ENCRYPTION_KEY
#   openssl rand -base64 32               # VAULT_KEY
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# CORE SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=4500
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE (SQLite — file path inside the container)
# ═══════════════════════════════════════════════════════════════════════════

DB_PATH=/app/data/myapi.db

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY & ENCRYPTION
# ═══════════════════════════════════════════════════════════════════════════

# Generate secure random value: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-change-me-generate-with-openssl-rand-hex-32

# Generate secure random value: openssl rand -hex 32
SESSION_SECRET=your-session-secret-change-me-generate-with-openssl-rand-hex-32

# 32-character encryption key for OAuth tokens (MUST be exactly 32 chars)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Generate secure random value: openssl rand -base64 32
VAULT_KEY=your-vault-key-change-me-generate-with-openssl-rand-base64-32

# Set to true in production (HTTPS only). false = allow HTTP (dev/tunnel)
SESSION_COOKIE_SECURE=true

# ═══════════════════════════════════════════════════════════════════════════
# URLS & NETWORKING
# ═══════════════════════════════════════════════════════════════════════════

BASE_URL=https://your-domain.com
PUBLIC_URL=https://your-domain.com

# Comma-separated allowed origins (supports wildcards like https://*.example.com)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ═══════════════════════════════════════════════════════════════════════════
# USER IDENTITY & CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Power user email for admin panel access
POWER_USER_EMAIL=owner@example.com

# Paths to USER.md and SOUL.md (mounted as volumes in docker-compose)
USER_MD_PATH=/app/config/USER.md
SOUL_MD_PATH=/app/config/SOUL.md

# ═══════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════════
# OAUTH PROVIDER FLAGS - Enable the services you actually use
# ═══════════════════════════════════════════════════════════════════════════

ENABLE_OAUTH_GOOGLE=false
ENABLE_OAUTH_GITHUB=false
ENABLE_OAUTH_FACEBOOK=false
ENABLE_OAUTH_SLACK=false
ENABLE_OAUTH_DISCORD=false
ENABLE_OAUTH_TWITTER=false
ENABLE_OAUTH_LINKEDIN=false
ENABLE_OAUTH_TIKTOK=false
ENABLE_OAUTH_REDDIT=false
ENABLE_OAUTH_INSTAGRAM=false
ENABLE_OAUTH_MICROSOFT365=false
ENABLE_OAUTH_DROPBOX=false
ENABLE_OAUTH_TRELLO=false
ENABLE_OAUTH_ZOOM=false
ENABLE_OAUTH_HUBSPOT=false
ENABLE_OAUTH_SALESFORCE=false
ENABLE_OAUTH_JIRA=false
ENABLE_OAUTH_CONFLUENCE=false
ENABLE_OAUTH_ASANA=false
ENABLE_OAUTH_LINEAR=false
ENABLE_OAUTH_MONDAY=false
ENABLE_OAUTH_CLICKUP=false
ENABLE_OAUTH_NOTION=false
ENABLE_OAUTH_THREADS=false
ENABLE_OAUTH_BOX=false
ENABLE_OAUTH_AIRTABLE=false
ENABLE_OAUTH_FIGMA=false
ENABLE_OAUTH_CANVA=false
ENABLE_OAUTH_ZENDESK=false
ENABLE_OAUTH_INTERCOM=false

# ═══════════════════════════════════════════════════════════════════════════
# OAUTH CREDENTIALS - Add only for enabled services
# ═══════════════════════════════════════════════════════════════════════════

# GOOGLE — Email, Calendar, Drive, Gmail, Maps
# Setup: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/oauth/callback/google
GOOGLE_MAPS_API_KEY=

# GITHUB — Repositories, Issues, Pull Requests
# Setup: https://github.com/settings/developers
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-domain.com/api/v1/oauth/callback/github

# FACEBOOK & INSTAGRAM — Pages, Posts, Messaging
# Setup: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://your-domain.com/api/v1/oauth/callback/facebook

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://your-domain.com/api/v1/oauth/callback/instagram

# TWITTER/X — Posts, Messages, Followers
