# ═══════════════════════════════════════════════════════════════════════════
# PAYMENT & BILLING
# ═══════════════════════════════════════════════════════════════════════════

# STRIPE — Payment Processing, Subscriptions
# Setup: https://dashboard.stripe.com/apikeys
STRIPE_ACCOUNT_ID=
STRIPE_API_VERSION=2025-12-15.clover
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_LIVE=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=
STRIPE_WEBHOOK_URL=https://your-domain.com/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET_SNAPSHOT=
STRIPE_WEBHOOK_SECRET_THIN=

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL SERVICE
# ═══════════════════════════════════════════════════════════════════════════

# Email provider: 'resend' (recommended) | 'smtp' | 'sendgrid'
EMAIL_PROVIDER=resend

# Sender email and display name (required)
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=MyApi

# RESEND — Modern email API (recommended for Docker)
# Setup: https://resend.com/
RESEND_API_KEY=

# Alternative: SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false

# Alternative: SendGrid
# SENDGRID_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════════════

# Sentry error tracking (optional)
# Setup: https://sentry.io/
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
# CLOUDFLARE TUNNEL (Optional - for public HTTPS without opening ports)
# ═══════════════════════════════════════════════════════════════════════════

# Create tunnel: https://dash.cloudflare.com/
# Uncomment cloudflared service in docker-compose.yml and set:
# CLOUDFLARE_TUNNEL_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# BACKUP CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# BACKUP_DIR=/app/backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_MAX_COUNT=50
# BACKUP_SCHEDULE_HOURS=24

# ═══════════════════════════════════════════════════════════════════════════
# CHATGPT INTEGRATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Enable ChatGPT Custom GPTs to connect via OAuth
# Setup: Create GPT at https://chatgpt.com/gpts
CHATGPT_OAUTH_CLIENT_ID=chatgpt
CHATGPT_OAUTH_CLIENT_SECRET=your-chatgpt-oauth-client-secret
CHATGPT_OAUTH_REDIRECT_URIS=https://chatgpt.com/aip/g-*/oauth/callback
