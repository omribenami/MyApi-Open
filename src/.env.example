# MyApi Platform Configuration - Example Environment Variables
# Copy this file to .env and fill in with your actual values

# ===== Server Configuration =====
PORT=4500
NODE_ENV=development

# ===== Security =====
JWT_SECRET=your-secret-key-here-change-in-production
ENCRYPTION_KEY=32-character-encryption-key-here!!
SESSION_SECRET=your-session-secret-key-here

# ===== Database =====
DB_PATH=./data/myapi.db

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:4500,http://localhost:3000,http://127.0.0.1:4500

# ===== User Identity =====
USER_MD_PATH=/path/to/USER.md
SOUL_MD_PATH=/path/to/SOUL.md

# ===== OAuth Configuration =====
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/github

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/facebook

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/slack

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/discord

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_API_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/whatsapp

# ===== API Configuration =====
API_VERSION=1.0.0
API_DOCS_URL=http://localhost:4500/api/v1/docs

# ===== Logging =====
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== Email (Optional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@myapi.local

# ===== Sentry Error Tracking (Optional) =====
SENTRY_DSN=https://your-sentry-dsn

# ===== Feature Flags =====
ENABLE_OAUTH_GOOGLE=true
ENABLE_OAUTH_GITHUB=true
ENABLE_OAUTH_FACEBOOK=true
ENABLE_OAUTH_SLACK=true
ENABLE_OAUTH_DISCORD=true
ENABLE_OAUTH_WHATSAPP=false
