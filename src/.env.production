# ========================================
# MyApi Production Environment
# ========================================
# CRITICAL: This file must be secured and never committed to version control.
# All secrets below MUST be replaced with actual production values.
# Use Docker secrets or environment variable management (e.g., 1Password, HashiCorp Vault).
#
# PRODUCTION CHECKLIST:
# [ ] Replace ALL placeholder values with real production secrets
# [ ] Use strong, randomly generated secrets (openssl rand -hex 32)
# [ ] Store this file securely outside of the repository
# [ ] Use CI/CD secrets management (GitHub Secrets, GitLab CI vars, etc.)
# [ ] Enable HTTPS for all OAuth redirect URIs
# [ ] Verify ALLOWED_ORIGINS are restricted to production domain only
# [ ] Test database backups and recovery procedures
# [ ] Monitor application logs and errors

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=4500
BASE_URL=https://www.myapiai.com
PUBLIC_URL=https://www.myapiai.com

# ========================================
# DATABASE
# ========================================
# SQLite database path in Docker - uses persistent volume
# The volume is configured in docker-compose.yml
DB_PATH=/app/data/myapi.db

# ========================================
# SECURITY - CRITICAL: CHANGE THESE VALUES!
# ========================================
# JWT secret for signing tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_PRODUCTION_JWT_SECRET

# Session secret for signing session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_PRODUCTION_SESSION_SECRET

# Cookie security: Set to 'true' for HTTPS production (recommended)
# Sessions will ONLY be transmitted over HTTPS
SESSION_COOKIE_SECURE=true

# Encryption key for sensitive data (must be 32 characters)
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_PROD_ENCRYPTION_KEY!

# ========================================
# CORS & ALLOWED ORIGINS
# ========================================
# PRODUCTION: Only allow your actual domain
ALLOWED_ORIGINS=https://www.myapiai.com,https://myapiai.com

# ========================================
# RATE LIMITING
# ========================================
# Adjust based on your production traffic needs
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# USER IDENTITY
# ========================================
# In Docker, this points to a mounted volume or config file
USER_MD_PATH=/app/data/USER.md

# ========================================
# OAUTH PROVIDERS - Google
# ========================================
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/google
GOOGLE_CALLBACK_URL=https://www.myapiai.com/api/v1/oauth/callback/google

# ========================================
# OAUTH PROVIDERS - GitHub
# ========================================
GITHUB_APP_ID=CHANGE_ME
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/github

# ========================================
# OAUTH PROVIDERS - TikTok
# ========================================
TIKTOK_CLIENT_KEY=CHANGE_ME
TIKTOK_CLIENT_SECRET=CHANGE_ME
TIKTOK_APP_ID=CHANGE_ME
TIKTOK_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/tiktok

# ========================================
# OAUTH PROVIDERS - Slack
# ========================================
SLACK_CLIENT_ID=CHANGE_ME
SLACK_CLIENT_SECRET=CHANGE_ME
SLACK_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/slack

# ========================================
# OAUTH PROVIDERS - LinkedIn
# ========================================
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME
LINKEDIN_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/linkedin

# ========================================
# OAUTH PROVIDERS - Facebook
# ========================================
FACEBOOK_CLIENT_ID=CHANGE_ME
FACEBOOK_CLIENT_SECRET=CHANGE_ME
FACEBOOK_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/facebook

# ========================================
# OAUTH PROVIDERS - Twitter/X
# ========================================
TWITTER_CLIENT_ID=CHANGE_ME
TWITTER_CLIENT_SECRET=CHANGE_ME
TWITTER_BEARER_TOKEN=CHANGE_ME
TWITTER_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/twitter

# ========================================
# OAUTH PROVIDERS - Discord
# ========================================
DISCORD_CLIENT_ID=CHANGE_ME
DISCORD_CLIENT_SECRET=CHANGE_ME
DISCORD_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/discord

# ========================================
# EXTERNAL SERVICES
# ========================================
# OpenAI API Key (if using AI features)
OPENAI_API_KEY=CHANGE_ME

# ========================================
# PRODUCTION DEPLOYMENT NOTES
# ========================================
# 1. Docker Deployment:
#    - Use: docker-compose -f docker-compose.yml --env-file .env.production up -d
#    - Volumes (myapi-data, myapi-logs) will persist to ./data and ./logs
#
# 2. Secret Management:
#    - Never commit this file with real values
#    - Use Docker Secrets or external secret managers (1Password, Vault, etc.)
#    - Example: docker secrets create myapi_jwt_secret <(echo "actual-secret")
#
# 3. Monitoring:
#    - Check logs: docker logs myapi-platform
#    - Health endpoint: curl http://localhost:4500/health
#    - Monitor /app/logs/ directory for application logs
#
# 4. Database Backups:
#    - Regular backups of /app/data/myapi.db are CRITICAL
#    - Use docker volumes inspect myapi_myapi-data to find data location
#    - Set up automated backup routines
#
# 5. Updates:
#    - Rebuild image: docker-compose build
#    - Restart container: docker-compose restart
