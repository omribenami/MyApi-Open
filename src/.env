# MyApi Platform Configuration

# Server
PORT=3001
NODE_ENV=development

# Security
JWT_SECRET=myapi-dev-secret-key-change-in-production-$(uuidgen)
ENCRYPTION_KEY=32characterencryptionkeyhere!!

# Database
DB_PATH=./data/myapi.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://192.168.1.253:3001

# User Identity
USER_MD_PATH=/home/jarvis/.openclaw/workspace/USER.md

# OPENAI_API_KEY is intentionally unset in tracked .env

BASE_URL=https://www.myapiai.com
PUBLIC_URL=https://www.myapiai.com

# Google OAuth
GOOGLE_CLIENT_ID=REMOVED_CLIENT_ID
GOOGLE_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/google
# NOTE: add real secret value from Google Console
GOOGLE_CLIENT_SECRET=
# Backward-compat alias
GOOGLE_CALLBACK_URL=https://www.myapiai.com/api/v1/oauth/callback/google
