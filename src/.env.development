# ========================================
# MyApi Development Environment
# ========================================
# This file is for local development only.
# Do NOT commit secrets to version control.
# Use this file as a template and fill in your local values.

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=4500
BASE_URL=http://localhost:4500
PUBLIC_URL=http://localhost:4500

# ========================================
# DATABASE
# ========================================
# SQLite database path (relative to src/)
DB_PATH=./data/myapi.db

# ========================================
# SECURITY
# ========================================
# NEVER use development secrets in production!
# Generate strong secrets: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production
ENCRYPTION_KEY=dev-key-32-characters-long-change!

# ========================================
# CORS & ALLOWED ORIGINS
# ========================================
ALLOWED_ORIGINS=http://localhost:4500,http://localhost:3001,http://127.0.0.1:3001,http://127.0.0.1:4500

# ========================================
# RATE LIMITING
# ========================================
# 15 minutes in milliseconds
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# USER IDENTITY
# ========================================
# Path to the USER.md file containing your identity
USER_MD_PATH=/home/jarvis/.openclaw/workspace/USER.md

# ========================================
# OAUTH PROVIDERS - Google
# ========================================
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/google
GOOGLE_CALLBACK_URL=http://localhost:4500/api/v1/oauth/callback/google

# ========================================
# OAUTH PROVIDERS - GitHub
# ========================================
GITHUB_APP_ID=your-github-app-id
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/github

# ========================================
# OAUTH PROVIDERS - TikTok
# ========================================
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/tiktok

# ========================================
# OAUTH PROVIDERS - Slack
# ========================================
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/slack

# ========================================
# OAUTH PROVIDERS - LinkedIn
# ========================================
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/linkedin

# ========================================
# OAUTH PROVIDERS - Facebook
# ========================================
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/facebook

# ========================================
# OAUTH PROVIDERS - Twitter/X
# ========================================
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/twitter

# ========================================
# OAUTH PROVIDERS - Discord
# ========================================
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/discord

# ========================================
# EXTERNAL SERVICES
# ========================================
# OpenAI API Key (optional, for AI features)
# OPENAI_API_KEY=your-openai-api-key-here

# ========================================
# DEVELOPMENT NOTES
# ========================================
# - Use `npm run dev` to start with nodemon (auto-reload)
# - Database will be initialized at DB_PATH on startup
# - All OAuth providers need to be configured for testing
# - See .env.example for additional configuration options
