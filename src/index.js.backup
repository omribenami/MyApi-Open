const express = require("express");
const helmet = require("helmet");
const cors = require("cors");
const bcrypt = require("bcrypt");
const jwt = require("jsonwebtoken");
const fs = require("fs");
const path = require("path");
const crypto = require("crypto");

const app = express();
const PORT = process.env.PORT || 4500;
const JWT_SECRET = process.env.JWT_SECRET || crypto.randomBytes(32).toString("hex");

// --- Middleware ---
app.use(helmet());
app.use(cors({ origin: process.env.CORS_ORIGIN || "*" }));
app.use(express.json({ limit: "100kb" }));
app.use(express.static(path.join(__dirname, "public")));

// --- In-Memory Stores (MVP; replace with SQLite/Postgres later) ---
const vault = {
  identityDocs: {},
  preferences: {},
  connectors: [],
};

const tokens = {};    // tokenId -> { hash, ownerId, scope, label, createdAt, revokedAt }
const auditLog = [];  // { timestamp, requesterId, action, resource, scope, ip }

let masterTokenId = null;

// --- Helpers ---
function generateTokenId() {
  return "tok_" + crypto.randomBytes(16).toString("hex");
}

function logAudit(entry) {
  auditLog.push({ timestamp: new Date().toISOString(), ...entry });
  // Keep last 10000 entries in memory
  if (auditLog.length > 10000) auditLog.shift();
}

// --- Auth Middleware (The Brain's gatekeeper) ---
function authenticate(req, res, next) {
  const authHeader = req.headers["authorization"] || "";
  const parts = authHeader.split(" ");
  if (parts.length !== 2 || parts[0] !== "Bearer") {
    return res.status(401).json({ error: "Missing or invalid Authorization header" });
  }
  const rawToken = parts[1];

  // Find matching token
  let matched = null;
  for (const [id, meta] of Object.entries(tokens)) {
    if (!meta.revokedAt && bcrypt.compareSync(rawToken, meta.hash)) {
      matched = { id, ...meta };
      break;
    }
  }

  if (!matched) {
    logAudit({ requesterId: "unknown", action: "auth_fail", resource: req.path, scope: null, ip: req.ip });
    return res.status(401).json({ error: "Invalid or revoked token" });
  }

  req.tokenMeta = matched;
  next();
}

// --- Personal Brain: scope filter ---
function filterByScope(data, scope) {
  if (scope === "full") return data;
  // For guest scopes, only return allowed fields
  const scopeFields = {
    "professional": ["name", "role", "company", "skills", "education"],
    "availability": ["availability", "timezone", "calendar"],
    "read": ["name", "role", "company"],
  };
  const allowed = scopeFields[scope] || scopeFields["read"];
  const filtered = {};
  for (const key of allowed) {
    if (data[key] !== undefined) filtered[key] = data[key];
  }
  return filtered;
}

// --- Rate Limiter (simple in-memory) ---
const rateLimitMap = {};
function rateLimit(windowMs = 60000, maxRequests = 60) {
  return (req, res, next) => {
    const key = req.ip;
    const now = Date.now();
    if (!rateLimitMap[key]) rateLimitMap[key] = [];
    rateLimitMap[key] = rateLimitMap[key].filter(t => now - t < windowMs);
    if (rateLimitMap[key].length >= maxRequests) {
      return res.status(429).json({ error: "Rate limit exceeded" });
    }
    rateLimitMap[key].push(now);
    res.set("X-RateLimit-Limit", String(maxRequests));
    res.set("X-RateLimit-Remaining", String(maxRequests - rateLimitMap[key].length));
    next();
  };
}
app.use(rateLimit());

// --- Bootstrap: create master token on first run ---
function bootstrap() {
  const rawMaster = crypto.randomBytes(32).toString("hex");
  const id = generateTokenId();
  const hash = bcrypt.hashSync(rawMaster, 10);
  tokens[id] = { hash, ownerId: "owner", scope: "full", label: "Master Token", createdAt: new Date().toISOString(), revokedAt: null };
  masterTokenId = id;

  // Load identity from USER.md if available
  const userMdPath = path.join(__dirname, "..", "..", "..", "USER.md");
  if (fs.existsSync(userMdPath)) {
    const raw = fs.readFileSync(userMdPath, "utf-8");
    vault.identityDocs["owner"] = parseUserMd(raw);
  } else {
    vault.identityDocs["owner"] = { name: "User", role: "Unknown" };
  }

  console.log("=== MyApi MVP Started ===");
  console.log(`Master Token (SAVE THIS): ${rawMaster}`);
  console.log(`Token ID: ${id}`);
  console.log(`Listening on port ${PORT}`);
  console.log("========================");
  return rawMaster;
}

function parseUserMd(raw) {
  const result = {};
  const lines = raw.split("\n");
  for (const line of lines) {
    const match = line.match(/^\s*[-*]\s*\*\*(.+?)\*\*[:\s]*(.+)/);
    if (match) {
      const key = match[1].trim().toLowerCase().replace(/\s+/g, "_");
      result[key] = match[2].trim();
    }
  }
  return result;
}

// ============================
// ROUTES
// ============================

// Health
app.get("/health", (req, res) => {
  res.json({ status: "ok", uptime: process.uptime() });
});

// GET /api/v1/identity
app.get("/api/v1/identity", authenticate, (req, res) => {
  const identity = vault.identityDocs["owner"] || {};
  const filtered = filterByScope(identity, req.tokenMeta.scope);
  logAudit({ requesterId: req.tokenMeta.id, action: "read_identity", resource: "/identity", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: filtered, meta: { scope: req.tokenMeta.scope } });
});

// GET /api/v1/identity/professional
app.get("/api/v1/identity/professional", authenticate, (req, res) => {
  const identity = vault.identityDocs["owner"] || {};
  const filtered = filterByScope(identity, "professional");
  logAudit({ requesterId: req.tokenMeta.id, action: "read_identity_professional", resource: "/identity/professional", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: filtered, meta: { scope: "professional" } });
});

// GET /api/v1/identity/availability
app.get("/api/v1/identity/availability", authenticate, (req, res) => {
  const identity = vault.identityDocs["owner"] || {};
  const filtered = filterByScope(identity, "availability");
  logAudit({ requesterId: req.tokenMeta.id, action: "read_availability", resource: "/identity/availability", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: filtered, meta: { scope: "availability" } });
});

// GET /api/v1/preferences
app.get("/api/v1/preferences", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Insufficient scope" });
  }
  logAudit({ requesterId: req.tokenMeta.id, action: "read_preferences", resource: "/preferences", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: vault.preferences["owner"] || {} });
});

// PUT /api/v1/preferences
app.put("/api/v1/preferences", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Insufficient scope" });
  }
  vault.preferences["owner"] = { ...vault.preferences["owner"], ...req.body };
  logAudit({ requesterId: req.tokenMeta.id, action: "update_preferences", resource: "/preferences", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: vault.preferences["owner"] });
});

// POST /api/v1/tokens - Create guest token
app.post("/api/v1/tokens", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Only master token can create tokens" });
  }
  const { scope = "read", label = "Guest Token", expiresInHours } = req.body;
  const validScopes = ["read", "professional", "availability"];
  if (!validScopes.includes(scope)) {
    return res.status(400).json({ error: `Invalid scope. Allowed: ${validScopes.join(", ")}` });
  }

  const rawToken = crypto.randomBytes(32).toString("hex");
  const id = generateTokenId();
  const hash = bcrypt.hashSync(rawToken, 10);
  const createdAt = new Date().toISOString();
  let expiresAt = null;
  if (expiresInHours) {
    expiresAt = new Date(Date.now() + expiresInHours * 3600000).toISOString();
  }

  tokens[id] = { hash, ownerId: "owner", scope, label, createdAt, revokedAt: null, expiresAt };
  logAudit({ requesterId: req.tokenMeta.id, action: "create_token", resource: `/tokens/${id}`, scope: req.tokenMeta.scope, ip: req.ip });
  res.status(201).json({ data: { tokenId: id, token: rawToken, scope, label, createdAt, expiresAt } });
});

// DELETE /api/v1/tokens/:id - Revoke token
app.delete("/api/v1/tokens/:id", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Only master token can revoke tokens" });
  }
  const tokenId = req.params.id;
  if (!tokens[tokenId]) {
    return res.status(404).json({ error: "Token not found" });
  }
  tokens[tokenId].revokedAt = new Date().toISOString();
  logAudit({ requesterId: req.tokenMeta.id, action: "revoke_token", resource: `/tokens/${tokenId}`, scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: { tokenId, revoked: true } });
});

// GET /api/v1/tokens - List tokens (master only)
app.get("/api/v1/tokens", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Only master token can list tokens" });
  }
  const list = Object.entries(tokens).map(([id, meta]) => ({
    tokenId: id,
    scope: meta.scope,
    label: meta.label,
    createdAt: meta.createdAt,
    revokedAt: meta.revokedAt,
    expiresAt: meta.expiresAt || null,
    active: !meta.revokedAt,
  }));
  logAudit({ requesterId: req.tokenMeta.id, action: "list_tokens", resource: "/tokens", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: list });
});

// GET /api/v1/audit - Audit log (master only)
app.get("/api/v1/audit", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Only master token can view audit log" });
  }
  const page = parseInt(req.query.page) || 1;
  const limit = Math.min(parseInt(req.query.limit) || 50, 100);
  const start = (page - 1) * limit;
  const logs = auditLog.slice().reverse().slice(start, start + limit);
  res.json({ data: logs, meta: { total: auditLog.length, page, limit } });
});

// GET /api/v1/connectors
app.get("/api/v1/connectors", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Insufficient scope" });
  }
  logAudit({ requesterId: req.tokenMeta.id, action: "list_connectors", resource: "/connectors", scope: req.tokenMeta.scope, ip: req.ip });
  res.json({ data: vault.connectors });
});

// POST /api/v1/connectors
app.post("/api/v1/connectors", authenticate, (req, res) => {
  if (req.tokenMeta.scope !== "full") {
    return res.status(403).json({ error: "Insufficient scope" });
  }
  const { type, config, label } = req.body;
  if (!type || !label) {
    return res.status(400).json({ error: "type and label are required" });
  }
  const connector = { id: crypto.randomUUID(), type, config: config || {}, label, createdAt: new Date().toISOString(), active: true };
  vault.connectors.push(connector);
  logAudit({ requesterId: req.tokenMeta.id, action: "add_connector", resource: `/connectors/${connector.id}`, scope: req.tokenMeta.scope, ip: req.ip });
  res.status(201).json({ data: connector });
});

// --- Dashboard (serve static HTML) ---
app.get("/dashboard", (req, res) => {
  res.sendFile(path.join(__dirname, "public", "dashboard.html"));
});

// --- Start ---
const masterRaw = bootstrap();
app.listen(PORT);
