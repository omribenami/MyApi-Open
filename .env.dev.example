# MyApi Platform Configuration - Example Environment Variables
# Copy this file to .env and fill in with your actual values

# ===== Server Configuration =====
PORT=4500
NODE_ENV=development

# ===== Security =====
JWT_SECRET=your-secret-key-here-change-in-production
ENCRYPTION_KEY=32-character-encryption-key-here!!
SESSION_SECRET=your-session-secret-key-here
VAULT_KEY=your-vault-key-here-change-in-production
# Set to 'true' in production (HTTPS only). Set to 'false' for local development (HTTP).
SESSION_COOKIE_SECURE=false

# ===== Database =====
DB_PATH=./data/myapi.db

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== CORS =====
# Comma-separated explicit origins (supports wildcard entries like https://*.example.com)
CORS_ORIGIN=http://localhost:4500,http://localhost:3000,http://127.0.0.1:4500

# ===== User Identity =====
USER_MD_PATH=/path/to/USER.md
SOUL_MD_PATH=/path/to/SOUL.md

# ===== Owner / Admin =====
# Required for User Management access-gate in dashboard
POWER_USER_EMAIL=owner@example.com

# ===== OAuth Configuration =====
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/github

# Facebook OAuth
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/facebook

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/slack

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/discord

# WhatsApp Business API
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_API_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/whatsapp

# Instagram OAuth
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/instagram

# TikTok OAuth
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/tiktok

# X / Twitter OAuth
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/twitter

# Reddit OAuth
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/reddit

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/linkedin

# Microsoft 365 OAuth
MICROSOFT365_CLIENT_ID=your-microsoft365-client-id
MICROSOFT365_CLIENT_SECRET=your-microsoft365-client-secret
MICROSOFT365_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/microsoft365

# Dropbox OAuth
DROPBOX_CLIENT_ID=your-dropbox-client-id
DROPBOX_CLIENT_SECRET=your-dropbox-client-secret
DROPBOX_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/dropbox

# Trello OAuth (custom OAuth 1.0a may be required)
TRELLO_CLIENT_ID=your-trello-client-id
TRELLO_CLIENT_SECRET=your-trello-client-secret
TRELLO_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/trello

# Zoom OAuth
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/zoom

# HubSpot OAuth
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/hubspot

# Salesforce OAuth
SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/salesforce

# Jira OAuth
JIRA_CLIENT_ID=your-jira-client-id
JIRA_CLIENT_SECRET=your-jira-client-secret
JIRA_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/jira

# ===== API Configuration =====
API_VERSION=1.0.0
API_DOCS_URL=http://localhost:4500/api/v1/docs

# ===== Logging =====
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== Email (Outbound only) =====
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@myapiai.com  # required deployment sender
EMAIL_FROM_NAME=MyApi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# SMTP_SECURE=false
# Optional if EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# ===== Sentry Error Tracking (Optional) =====
SENTRY_DSN=https://your-sentry-dsn

# ===== Feature Flags =====
ENABLE_OAUTH_GOOGLE=true
ENABLE_OAUTH_GITHUB=true
ENABLE_OAUTH_FACEBOOK=true
ENABLE_OAUTH_SLACK=true
ENABLE_OAUTH_DISCORD=true
ENABLE_OAUTH_WHATSAPP=false
ENABLE_OAUTH_INSTAGRAM=false
ENABLE_OAUTH_TIKTOK=false
ENABLE_OAUTH_TWITTER=false
ENABLE_OAUTH_REDDIT=false
ENABLE_OAUTH_LINKEDIN=false
ENABLE_OAUTH_MICROSOFT365=false
ENABLE_OAUTH_DROPBOX=false
ENABLE_OAUTH_TRELLO=false
ENABLE_OAUTH_ZOOM=false
ENABLE_OAUTH_HUBSPOT=false
ENABLE_OAUTH_SALESFORCE=false
ENABLE_OAUTH_JIRA=false

# ===== SSL/TLS Configuration =====
# SSL_ENABLED=false
# SSL_DOMAIN=api.example.com
# SSL_EMAIL=admin@example.com
# SSL_CERT_DIR=./certs

# ===== Cloudflare Integration =====
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# ===== Backup Configuration =====
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_MAX_COUNT=50
# BACKUP_SCHEDULE_HOURS=24
