node_modules/
*.sqlite
.env
dist/
*.log

# Python cache artifacts
__pycache__/
*.pyc

# SQLite runtime files (never commit live DBs/WALs)
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
*.db-shm
*.db-wal
src/data/*.db
src/data/*.db-shm
src/data/*.db-wal
src/.db_integrity
:memory:
:memory:-shm
:memory:-wal

# Build/cache
.cache/

# Local virtual environment
backend/venv/

# Local KB uploaded files
src/uploads/

# Environment files - NEVER commit real secrets!
src/.env*
!src/.env.example
.env.local
logs/

# Backups (may contain sensitive data)
backups/

# SSL certificates (sensitive)
certs/
certbot/

# Docker-managed data volumes (when using bind mounts)
data/
backend/data/

# Stray database files
backend/*.db
backend/*.db-shm
backend/*.db-wal
