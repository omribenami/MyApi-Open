{
  "llm": {
    "model": "gemini-pro",
    "temperature": 0.7,
    "topP": 0.9,
    "maxTokens": 2048,
    "streaming": false,
    "providers": {
      "gemini": {
        "enabled": true,
        "apiKeyEnv": "GOOGLE_API_KEY",
        "models": ["gemini-pro", "gemini-pro-vision"]
      },
      "openai": {
        "enabled": false,
        "apiKeyEnv": "OPENAI_API_KEY",
        "models": ["gpt-4", "gpt-3.5-turbo"]
      },
      "claude": {
        "enabled": false,
        "apiKeyEnv": "ANTHROPIC_API_KEY",
        "models": ["claude-opus", "claude-haiku"]
      },
      "ollama": {
        "enabled": false,
        "baseUrl": "http://localhost:11434",
        "models": ["llama2", "neural-chat"]
      }
    }
  },
  "embeddings": {
    "model": "simple-hash",
    "dimension": 384,
    "chunkSize": 500,
    "minChunkSize": 50
  },
  "context": {
    "maxHistoryMessages": 10,
    "cacheEnabled": true,
    "cacheTTL": 3600,
    "includes": {
      "userProfile": true,
      "persona": true,
      "memory": true,
      "conversationHistory": true
    }
  },
  "knowledgeBase": {
    "autoSeedOnStart": true,
    "seedDocuments": ["USER.md", "SOUL.md", "MEMORY.md"],
    "maxDocuments": 1000,
    "searchTopK": 3
  },
  "conversation": {
    "retentionDays": 90,
    "maxConversations": 100,
    "autoDeleteExpired": true
  },
  "security": {
    "encryptMessages": false,
    "rateLimitPerMinute": 30,
    "auditLogging": true,
    "allowPrivateMessages": true
  },
  "features": {
    "contextAssembly": true,
    "semanticSearch": true,
    "conversationMemory": true,
    "toolSupport": false,
    "streaming": false
  }
}
