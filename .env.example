# MyApi Platform Configuration - Complete Environment Variables
# Copy this file to .env and fill in with your actual values
# Services are organized by category below

# ═══════════════════════════════════════════════════════════════════════════
# CORE SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

PORT=4500
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY & ENCRYPTION
# ═══════════════════════════════════════════════════════════════════════════

# JWT token signing key for session authentication
JWT_SECRET=your-secret-key-here-change-in-production

# AES-256-GCM encryption key for OAuth tokens (MUST be exactly 32 characters)
ENCRYPTION_KEY=32-character-encryption-key-here!!

# Session/cookie signing key for Express sessions
SESSION_SECRET=your-session-secret-key-here

# Vault encryption key for storing API credentials (MUST be 32 chars)
VAULT_KEY=your-vault-key-here-change-in-production

# Set to 'true' in production (HTTPS only). Set to 'false' for local development
SESSION_COOKIE_SECURE=false

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════

# SQLite database path (relative or absolute)
DB_PATH=./data/myapi.db

# Optional: PostgreSQL connection string (if using Postgres instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/myapi

# ═══════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════

# Time window for rate limiting in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP address
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════════
# CORS & NETWORKING
# ═══════════════════════════════════════════════════════════════════════════

# Comma-separated list of allowed origins (supports wildcards like https://*.example.com)
ALLOWED_ORIGINS=http://localhost:4500,http://localhost:3000,http://127.0.0.1:4500

# ═══════════════════════════════════════════════════════════════════════════
# USER IDENTITY & CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Path to USER.md file (markdown with user profile, skills, background)
USER_MD_PATH=/path/to/USER.md

# Path to SOUL.md file (AI personality/character definition)
SOUL_MD_PATH=/path/to/SOUL.md

# Power user email for admin panel access
POWER_USER_EMAIL=owner@example.com

# ═══════════════════════════════════════════════════════════════════════════
# PUBLIC URLS
# ═══════════════════════════════════════════════════════════════════════════

# Base URL for API (used in generated links and OAuth redirects)
BASE_URL=https://www.myapiai.com
PUBLIC_URL=https://www.myapiai.com

# ═══════════════════════════════════════════════════════════════════════════
# OAUTH INTEGRATIONS - SOCIAL & MESSAGING
# ═══════════════════════════════════════════════════════════════════════════

# ─────── GOOGLE ───────
# Service: Email, Calendar, Drive, Gmail, Maps, Analytics
# Setup: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/google
GOOGLE_CALLBACK_URL=http://localhost:4500/api/v1/oauth/callback/google
# Maps API key for geocoding and location services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─────── GITHUB ───────
# Service: Repository access, Issues, Pull Requests, Gists
# Setup: https://github.com/settings/developers
GITHUB_APP_ID=your-github-app-id
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/github

# ─────── FACEBOOK & INSTAGRAM ───────
# Services: Facebook Pages, Instagram Posts, Messaging
# Setup: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/facebook

INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/instagram

# ─────── TWITTER / X ───────
# Service: Posts, Likes, Direct Messages, Followers
# Setup: https://developer.twitter.com/
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/twitter

# ─────── DISCORD ───────
# Service: Server access, Channels, Messages, Roles
# Setup: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/discord
# Bot token is stored per-user via PUT /api/v1/services/discord/preferences {"bot_token":"..."}

# ─────── SLACK ───────
# Service: Channels, Messages, Users, Workspace info
# Setup: https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/slack
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_VERIFICATION_TOKEN=your-slack-verification-token
SLACK_APP_ID=your-slack-app-id

# ─────── TIKTOK ───────
# Service: Posts, Videos, Likes, User info
# Setup: https://developer.tiktok.com/
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/tiktok

# ─────── REDDIT ───────
# Service: Posts, Comments, Subreddit management
# Setup: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/reddit

# ─────── LINKEDIN ───────
# Service: Profile, Job posting, Company updates, Messages
# Setup: https://www.linkedin.com/developers/
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/linkedin

