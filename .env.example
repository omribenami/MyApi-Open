# ═══════════════════════════════════════════════════════════════════════════
# OAUTH INTEGRATIONS - CUSTOMER SUPPORT & COMMUNICATION
# ═══════════════════════════════════════════════════════════════════════════

# ─────── ZENDESK ───────
# Service: Support tickets, Customer conversations, Knowledge base
# Setup: https://zendesk.com/apps/oauth
ZENDESK_SUBDOMAIN=your-zendesk-subdomain
ZENDESK_CLIENT_ID=your-zendesk-client-id
ZENDESK_CLIENT_SECRET=your-zendesk-client-secret
ZENDESK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/zendesk

# ─────── INTERCOM ───────
# Service: Customer messaging, Support, Chatbot
# Setup: https://app.intercom.io/a/settings/integrations
INTERCOM_CLIENT_ID=your-intercom-client-id
INTERCOM_CLIENT_SECRET=your-intercom-client-secret
INTERCOM_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/intercom

# ─────── THREADS ───────
# Service: Fediverse social network (Meta)
# Setup: Requires Threads app approval
THREADS_CLIENT_ID=your-threads-client-id
THREADS_CLIENT_SECRET=your-threads-client-secret
THREADS_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/threads

# ═══════════════════════════════════════════════════════════════════════════
# PAYMENT & BILLING
# ═══════════════════════════════════════════════════════════════════════════

# ─────── STRIPE ───────
# Service: Payment processing, Subscriptions, Invoicing
# Setup: https://dashboard.stripe.com/apikeys
STRIPE_ACCOUNT_ID=your-stripe-account-id
STRIPE_API_VERSION=2025-12-15.clover

# Publishable keys (safe to expose in frontend)
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_your-test-key
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your-live-key

# Secret keys (keep private, server-only)
STRIPE_SECRET_KEY_TEST=sk_test_your-test-key
STRIPE_SECRET_KEY_LIVE=sk_live_your-live-key

# Webhook endpoints for payment events
STRIPE_WEBHOOK_URL=https://www.myapiai.com/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET_SNAPSHOT=whsec_your-snapshot-secret
STRIPE_WEBHOOK_SECRET_THIN=whsec_your-thin-secret

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL SERVICE
# ═══════════════════════════════════════════════════════════════════════════

# Email provider: 'resend' (recommended) | 'smtp' | 'sendgrid'
EMAIL_PROVIDER=resend

# Sender email and display name (required for all providers)
EMAIL_FROM=noreply@myapiai.com
EMAIL_FROM_NAME=MyApi

# ─────── RESEND (Recommended) ───────
# Setup: https://resend.com/
RESEND_API_KEY=your-resend-api-key

# ─────── SMTP Alternative ───────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_SECURE=false

# ─────── SendGrid Alternative ───────
# SENDGRID_API_KEY=your-sendgrid-api-key

# ═══════════════════════════════════════════════════════════════════════════
# ERROR TRACKING & MONITORING
# ═══════════════════════════════════════════════════════════════════════════

# Sentry error tracking (optional)
# Setup: https://sentry.io/
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ═══════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════

# Enable/disable OAuth providers (set to 'true' to enable)
ENABLE_OAUTH_GOOGLE=true
ENABLE_OAUTH_GITHUB=true
ENABLE_OAUTH_FACEBOOK=true
ENABLE_OAUTH_SLACK=true
ENABLE_OAUTH_DISCORD=true
ENABLE_OAUTH_INSTAGRAM=false
ENABLE_OAUTH_TIKTOK=false
ENABLE_OAUTH_TWITTER=false
ENABLE_OAUTH_REDDIT=false
ENABLE_OAUTH_LINKEDIN=false
ENABLE_OAUTH_MICROSOFT365=false
ENABLE_OAUTH_DROPBOX=false
ENABLE_OAUTH_TRELLO=false
ENABLE_OAUTH_ZOOM=false
ENABLE_OAUTH_HUBSPOT=false
ENABLE_OAUTH_SALESFORCE=false
ENABLE_OAUTH_JIRA=false
ENABLE_OAUTH_CONFLUENCE=false
ENABLE_OAUTH_ASANA=false
ENABLE_OAUTH_LINEAR=false
ENABLE_OAUTH_MONDAY=false
ENABLE_OAUTH_CLICKUP=false
ENABLE_OAUTH_NOTION=false
ENABLE_OAUTH_THREADS=false
ENABLE_OAUTH_BOX=false
ENABLE_OAUTH_AIRTABLE=false
ENABLE_OAUTH_FIGMA=false
ENABLE_OAUTH_CANVA=false
ENABLE_OAUTH_ZENDESK=false
ENABLE_OAUTH_INTERCOM=false

# ═══════════════════════════════════════════════════════════════════════════
# BETA MODE
# ═══════════════════════════════════════════════════════════════════════════
# When true: caps total users at BETA_MAX_USERS, only the Free plan is purchasable,
#   and signup attempts past the cap are redirected to an email-capture waitlist.
# When false: no user cap, all plans open for purchase via Stripe, beta badges hidden.
BETA=true
BETA_MAX_USERS=50

# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# SSL/TLS Configuration
# SSL_ENABLED=false
# SSL_DOMAIN=api.example.com
# SSL_EMAIL=admin@example.com
# SSL_CERT_DIR=./certs

# Backup Configuration
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_MAX_COUNT=50
# BACKUP_SCHEDULE_HOURS=24

# Cloudflare Integration
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Logging
# LOG_LEVEL=debug
# LOG_FORMAT=json

# API Documentation
# API_VERSION=1.0.0
# API_DOCS_URL=http://localhost:4500/api/v1/docs

# ═══════════════════════════════════════════════════════════════════════════
# CHATGPT INTEGRATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Enables ChatGPT Custom GPTs to connect to MyApi via OAuth
# Setup: Create GPT at https://chatgpt.com/gpts, use callback URL from Actions editor
CHATGPT_OAUTH_CLIENT_ID=chatgpt
CHATGPT_OAUTH_CLIENT_SECRET=your-chatgpt-oauth-client-secret
CHATGPT_OAUTH_REDIRECT_URIS=https://chatgpt.com/aip/g-*/oauth/callback
