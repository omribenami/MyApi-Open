# ============================================================================
# MyApi Configuration
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (choose one: sqlite or postgresql)
# ============================================================================

# DEFAULT: Local SQLite Database
# Uncomment to use local SQLite (no additional configuration needed)
DATABASE_TYPE=sqlite
DB_PATH=./data/myapi.db

# EXTERNAL: PostgreSQL Database (Supabase, RDS, or self-hosted)
# Uncomment and configure to use external PostgreSQL database
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://username:password@host:port/database

# Note: If DATABASE_URL is set, it takes precedence over DATABASE_TYPE
# You can also set just DATABASE_URL and the system will auto-detect PostgreSQL

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

NODE_ENV=production
PORT=4500
SESSION_COOKIE_SECURE=true

# ============================================================================
# ENCRYPTION & SECURITY KEYS
# ============================================================================

ENCRYPTION_KEY=32characterencryptionkeyhere!!
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here
VAULT_KEY=your-vault-key-here

# ============================================================================
# GOOGLE OAUTH (OAuth Login)
# ============================================================================

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/google
GOOGLE_CALLBACK_URL=https://www.myapiai.com/api/v1/oauth/callback/google
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ============================================================================
# OTHER OAUTH PROVIDERS (optional)
# ============================================================================

# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/github

# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_CLIENT_SECRET=your-discord-client-secret
# DISCORD_REDIRECT_URI=https://www.myapiai.com/api/v1/oauth/callback/discord

# ============================================================================
# EMAIL CONFIGURATION (for notifications)
# ============================================================================

EMAIL_PROVIDER=resend
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@myapiai.com
EMAIL_FROM_NAME=MyApi

# ============================================================================
# STRIPE BILLING (optional)
# ============================================================================

# STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_LIVE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# POWER USER EMAIL
# ============================================================================

POWER_USER_EMAIL=admin@example.com

# ============================================================================
# API KEYS (for external services)
# ============================================================================

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
